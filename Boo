<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Absolute Pitch Trainer - Eguchi Method</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f0f0f0; padding: 20px; }
        #status { margin-bottom: 20px; font-size: 1.2rem; font-weight: bold; text-align: center; height: 1.5em; }
        .button-container { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; max-width: 500px; }
        .chord-btn { width: 100px; height: 100px; border-radius: 15px; border: 4px solid white; cursor: pointer; transition: transform 0.1s; box-shadow: 0 4px 6px rgba(0,0,0,0.2); }
        .chord-btn:active { transform: scale(0.95); }
        #play-btn { padding: 15px 40px; font-size: 1.4rem; margin-bottom: 30px; cursor: pointer; background: #333; color: white; border-radius: 12px; border: none; font-weight: bold; }
        #play-btn:hover { background: #555; }
    </style>
</head>
<body>

    <div id="status">Press the button to hear a chord</div>
    <button id="play-btn">Play Random Chord</button>

    <div class="button-container" id="game-ui">
        </div>

<script>
    // --- 1. CONFIGURATION: ALL 9 EGUCHI CHORDS ---
    const chordConfig = [
        { name: "C Major (Red)", notes: [261.63, 329.63, 392.00], color: "#FF0000" },          // 1. Red
        { name: "F Major 2nd Inv (Brown)", notes: [261.63, 349.23, 440.00], color: "#8B4513" }, // 2. Brown
        { name: "G Major 1st Inv (Pink)", notes: [246.94, 293.66, 392.00], color: "#FFC0CB" },  // 3. Pink
        { name: "F Major 1st Inv (Purple)", notes: [220.00, 261.63, 349.23], color: "#800080" }, // 4. Purple
        { name: "G Major 2nd Inv (Orange)", notes: [293.66, 392.00, 493.88], color: "#FFA500" }, // 5. Orange
        { name: "C Major 1st Inv (Yellow)", notes: [329.63, 392.00, 523.25], color: "#FFFF00" }, // 6. Yellow
        { name: "F Major (Green)", notes: [349.23, 440.00, 523.25], color: "#008000" },          // 7. Green
        { name: "G Major (Teal)", notes: [392.00, 493.88, 587.33], color: "#008080" },           // 8. Teal
        { name: "C Major 2nd Inv (Grey)", notes: [392.00, 523.25, 659.25], color: "#808080" }   // 9. Grey
    ];

    let currentChordIndex = null;
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    function playTriad(frequencies) {
        frequencies.forEach(freq => {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = 'triangle'; 
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            
            gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 2.0);

            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start();
            osc.stop(audioCtx.currentTime + 2.0);
        });
    }

    const uiContainer = document.getElementById('game-ui');
    const statusText = document.getElementById('status');

    chordConfig.forEach((chord, index) => {
        const btn = document.createElement('button');
        btn.className = 'chord-btn';
        btn.style.backgroundColor = chord.color;
        // Added accessibility labels
        btn.setAttribute('aria-label', chord.name);
        btn.onclick = () => checkAnswer(index);
        uiContainer.appendChild(btn);
    });

    document.getElementById('play-btn').onclick = () => {
        if (audioCtx.state === 'suspended') audioCtx.resume();
        currentChordIndex = Math.floor(Math.random() * chordConfig.length);
        playTriad(chordConfig[currentChordIndex].notes);
        statusText.innerText = "Which color was that?";
        statusText.style.color = "black";
    };

    function checkAnswer(index) {
        if (currentChordIndex === null) return;
        if (index === currentChordIndex) {
            statusText.innerText = "Correct! " + chordConfig[index].name;
            statusText.style.color = "green";
        } else {
            statusText.innerText = "Try again!";
            statusText.style.color = "red";
        }
    }
</script>
</body>
</html>
